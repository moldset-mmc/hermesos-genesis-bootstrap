+def hkp_preflight_tool_call(name: str, args: dict | None = None) -> str | None:
+    """Run HKP preflight check on a tool call before dispatch.
+
+    In dry-run mode: log decision but return None (allow execution).
+    In enforcement mode: return error JSON string for non-ALLOWED results.
+
+    Returns None if ALLOWED (or dry-run), or an error dict JSON string if
+    BLOCKED/PROPOSE/DENY in enforcement mode.
+    """
+    result = preflight(name, args or {})
+    if result == PreflightResult.ALLOWED:
+        return None
+
+    # Dry-run mode — log decision but allow execution
+    if _is_dry_run():
+        logger.info(
+            "HKP_DRY_RUN tool=%s decision=%s args=%s",
+            name, result, json.dumps(args, default=str)[:200],
+        )
+        return None
+
+    if result == PreflightResult.PROPOSE:
+        return json.dumps({
+            "error": "HKP_PREFLIGHT_PROPOSE",
+            "message": f"Action '{name}' requires Owner approval before execution.",
+            "decision": "PROPOSE",
+            "preflight_result": result,
+        })
+    if result == PreflightResult.DENY:
+        return json.dumps({
+            "error": "HKP_PREFLIGHT_DENY",
+            "message": f"Action '{name}' is denied by HKP policy.",
+            "decision": "DENY",
+            "preflight_result": result,
+        })
+    # BLOCKED (default)
+    return json.dumps({
+        "error": "HKP_PREFLIGHT_BLOCKED",
+        "message": f"Action '{name}' is blocked in the current execution context.",
+        "decision": "BLOCKED",
+        "preflight_result": result,
+    })
+
+
