# HermesOS Profile Secrets Template
# COPY this file to profiles/hermesos/.env and FILL IN real values
# NEVER commit real secrets to version control
#
# Bootstrap-Required (MUST be set before first start):
TELEGRAM_BOT_TOKEN=__FILL_ME__                    # Telegram bot token (@MMCAssist_bot)
TELEGRAM_ALLOWED_USERS=__FILL_ME__                 # Comma-separated Telegram user IDs
OPENROUTER_API_KEY=__FILL_ME__                     # LLM provider primary key

# Bootstrap-Required Environment Variables (set via Hermes_Gateway.cmd or system env):
# HERMES_HOME = <hermes root directory>
# HKP_AUTHORITY_ROOT = <HKP canonical corpus path>

# Optional Provider Credentials:
TELEGRAM_GROUP_ALLOWED_USERS=__FILL_ME__
DEEPSEEK_API_KEY=__FILL_ME__
OPENCODE_GO_API_KEY=__FILL_ME__
GITHUB_TOKEN=__FILL_ME__

# Optional: SMS/Telephony (Twilio)
# TWILIO_ACCOUNT_SID=__FILL_ME__
# TWILIO_AUTH_TOKEN=__FILL_ME__

# Optional: Google Custom Search
# GOOGLE_CSE_API_KEY=__FILL_ME__
# GOOGLE_CSE_CX=__FILL_ME__

# Optional: Ed25519 approval key
# HKP_APPROVAL_PUBLIC_KEY_PATH=__FILL_ME__

# Optional: v0.dev integration
# V0_API_KEY=__FILL_ME__

# Optional: Linear MCP integration
# LINEAR_MCP_TOKEN=__FILL_ME__
