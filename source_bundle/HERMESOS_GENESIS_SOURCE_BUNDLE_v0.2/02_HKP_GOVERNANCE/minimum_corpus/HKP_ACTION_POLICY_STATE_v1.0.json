  "authority_order": [
    "HKP Constitution (HKP-FND-004)",
    "HKP Foundation documents (Genesis, Operating Model, Registry, Bootstrap, ADR, Glossary, Foundation Release)",
    "HERMES_OWNER_OPERATING_PROFILE_v1.0 (HKP-OPR-001)",
    "HKP Runtime, Specification, and Implementation Layer documents",
    "config.yaml director personality",
    ".hermes.md project context",
    "SOUL definition",
    "Skills (procedural memory)",
    "USER.md / MEMORY.md",
    "Channel-level prompts",
    "Runtime prompts"
  ],
  "decision_classes": [
    {
      "class": "OBSERVE_ONLY",
      "description": "Execute freely. Read-only actions only. No approval needed.",
      "applies_to": ["file_read", "config_read", "search", "knowledge_query", "listing", "inspection"]
    },
    {
      "class": "INTERNAL_REVERSIBLE",
      "description": "Execute freely if internal and fully reversible. Logged in session transcript.",
      "applies_to": ["draft_document_creation", "temporary_file_write", "non_critical_skill_create", "reversible_single_patch"]
    },
    {
      "class": "PROPOSE_AND_APPROVE",
      "description": "Propose to owner, wait for explicit approval, then execute.",
      "applies_to": ["canonical_publication", "non_foundation_hkp_edit", "recurring_cron", "system_skill_change", "profile_config_modify", "reputation_message"]
    },
    {
      "class": "OWNER_EXPLICIT_ORDER",
      "description": "Do not propose. Wait for explicit unambiguous owner directive.",
      "applies_to": ["hkp_foundation_edit", "gateway_start_stop", "daemon_route_modify", "credential_change", "governance_rule_change"]
    },
    {
      "class": "ALLOWLISTED_CRITICAL_RUNTIME",
      "description": "Execute on schedule without owner intervention. Pre-approved by HKP governance.",
      "applies_to": ["voice_bot_poller_cron"]
    },
    {
      "class": "QUARANTINED",
      "description": "Structurally permitted but currently disabled by quarantine order. Owner may unquarantine per-instance.",
      "applies_to": ["quarantined_no_agent_jobs", "background_review"]
    },
    {
      "class": "DENY",
      "description": "Forbidden by policy. Must not execute or propose. Only owner may override in-session.",
      "applies_to": ["foundation_edit_by_non_owner", "unregistered_daemon_routes", "profile_independent_cron", "constitutional_violations"]
    }
  ],
