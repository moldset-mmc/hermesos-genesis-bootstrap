{
  "GENESIS_PACKAGE_ROOT": "<OWNER_PROVIDED_PACKAGE_ROOT>",
  "HKP_CANONICAL_ROOT": "<OWNER_PROVIDED_AUTHORITATIVE_HKP_ROOT>",
  "HKP_EVIDENCE_ROOT": "<HOST_EVIDENCE_ROOT>",
